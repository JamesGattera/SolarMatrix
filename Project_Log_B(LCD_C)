// Industry Functions //
// Basic LCD Start //
spi_device_handle_t spi;

// LOW LEVEL BYTE SEND
void send_byte(unsigned char value, int is_data)
{
    if (is_data == 1) {
        gpio_set_level(PIN_DC, 1); //Data Mode
    } else {
        gpio_set_level(PIN_DC, 0); //Command Mode
    }

    spi_transaction_t t;
    memset(&t, 0, sizeof(t));
    t.length = 8;
    t.tx_buffer = &value;

    spi_device_polling_transmit(spi, &t);

    esp_task_wdt_reset();//keep system alive during heavy SPI
}

// LCD INIT
void lcd_start()
{
    //hardware reset cycle
    gpio_set_level(PIN_RST, 0);
    vTaskDelay(pdMS_TO_TICKS(100));
    gpio_set_level(PIN_RST, 1);
    vTaskDelay(pdMS_TO_TICKS(100));

    //wake panel
    send_byte(17, 0); //Sleep Out
    vTaskDelay(pdMS_TO_TICKS(120));

    //memory orientation (MADCTL)//trial values change rotation
    send_byte(54, 0);
    send_byte(0x00, 1); //adjust if rotated/mirrored

    //turn display on
    send_byte(41, 0);
    vTaskDelay(pdMS_TO_TICKS(12));
}

// SPI SETUP
void SetupSPI(){
    spi_bus_config_t bus = {0};
    bus.mosi_io_num = PIN_MOSI;
    bus.sclk_io_num = PIN_CLK;
    bus.miso_io_num = -1;

    spi_device_interface_config_t device = {0};
    device.clock_speed_hz = 40000000; //pushed higher for faster frames
    device.mode = 0;
    device.spics_io_num = PIN_CS;
    device.queue_size = 1;

    spi_bus_initialize(SPI2_HOST, &bus, SPI_DMA_CH_AUTO);
    spi_bus_add_device(SPI2_HOST, &device, &spi);
}

// Framebuffer //
uint8_t FrameBuffer[LCD_WIDTH * LCD_HEIGHT * 2]; //RGB565 full frame

// PIXEL CORE (absolute control)
void set_pixel(int x, int y, uint16_t color)
{
    if (x < 0 || x >= LCD_WIDTH || y < 0 || y >= LCD_HEIGHT) return;

    int i = (y * LCD_WIDTH + x) * 2;

    FrameBuffer[i]     = color >> 8;
    FrameBuffer[i + 1] = color & 0xFF;
}

// CLEAR SCREEN (fast fill)
void clear_screen(uint16_t color)
{
    for (int i = 0; i < LCD_WIDTH * LCD_HEIGHT; i++) {
        FrameBuffer[i*2]     = color >> 8;
        FrameBuffer[i*2 + 1] = color & 0xFF;
    }
}

// DRAW CHAR (5x7 raster write)
void draw_char(int x, int y, const uint8_t *char_data) {
    for (int col = 0; col < 5; col++) {
        uint8_t line = char_data[col];
        for (int row = 0; row < 7; row++) {
            if (line & (1 << row)) {
                set_pixel(x + col, y + row, 0xFFFF); //white pixel
            }
        }
    }
}

// SET LCD FULL WINDOW (16-bit safe)
void lcd_set_window()
{
    // Column (X)
    send_byte(42, 0);
    send_byte(0,1); send_byte(0,1); //start = 0
    send_byte((LCD_WIDTH-1)>>8,1);
    send_byte((LCD_WIDTH-1)&0xFF,1);

    // Row (Y)
    send_byte(43, 0);
    send_byte(0,1); send_byte(0,1); //start = 0
    send_byte((LCD_HEIGHT-1)>>8,1);
    send_byte((LCD_HEIGHT-1)&0xFF,1);
}

// SEND FRAMEBUFFER (bulk transfer)
void Send_FrameBuffer(){
    lcd_set_window();        //define target area
    send_byte(44, 0);        //memory write start

    spi_transaction_t t;
    memset(&t, 0, sizeof(t));
    t.length = sizeof(FrameBuffer)*8;
    t.tx_buffer = FrameBuffer;

    spi_device_polling_transmit(spi,&t);

    esp_task_wdt_reset(); //long transfer safety
}
void Send_Pixel_Block(int x, int y, uint16_t color)
{
    //set window to 1 pixel
    send_byte(42, 0);
    send_byte(0,1); send_byte(x,1);
    send_byte(0,1); send_byte(x,1);

    send_byte(43, 0);
    send_byte(0,1); send_byte(y,1);
    send_byte(0,1); send_byte(y,1);

    send_byte(44, 0);

    uint8_t data[2];
    data[0] = color >> 8;
    data[1] = color & 0xFF;

    spi_transaction_t t = {0};
    t.length = 16;
    t.tx_buffer = data;

    spi_device_polling_transmit(spi, &t);
}
